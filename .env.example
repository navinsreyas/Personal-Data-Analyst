# =============================================================================
# Personal Data Analyst — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and will never be pushed to GitHub.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Anthropic API Key
# Get yours at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# OPTIONAL — OpenAI fallback (used if ANTHROPIC_API_KEY is not set)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# OPTIONAL — LangSmith tracing (recommended for debugging)
# Get yours at: https://smith.langchain.com/
# -----------------------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=personal-data-analyst
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# -----------------------------------------------------------------------------
# OPTIONAL — API server settings (FastAPI only)
# -----------------------------------------------------------------------------
# MODEL_ID=claude-sonnet-4-6   # override the model used by the API
# PORT=8000                     # port for uvicorn (default: 8000)
